#version 450
// Exercises trans ALU (v_exp/v_log/v_sqrt) chain. 64 threads = 2 wave32.
layout(local_size_x = 64) in;
layout(set = 0, binding = 0) buffer B { float data[]; } buf;
void main() {
  uint i = gl_LocalInvocationID.x;
  float v = buf.data[i] + 0.125;
  v = exp(v); v = log(v); v = sqrt(v);
  v = exp(v); v = log(v); v = sqrt(v);
  v = exp(v); v = log(v); v = sqrt(v);
  buf.data[i] = v;
}
